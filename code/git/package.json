{
  "name": "@ncrmro/quiescent-git",
  "version": "0.1.0",
  "type": "module",
  "description": "Forge API abstraction (GitHub, Gitea, Forgejo, Codeberg) for committing and opening pull requests over HTTP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ncrmro/quiescent.git",
    "directory": "code/git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.8.0"
  }
}
