{
  "name": "@quiescent/editor",
  "version": "0.2.0",
  "type": "module",
  "description": "CodeMirror 6 markdown editor with idle detection for quiescent's flush-on-stop workflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ncrmro/quiescent.git",
    "directory": "code/editor"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.8.0"
  }
}
